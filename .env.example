# ─── SUPABASE ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── RESEND (email) ─────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ─── DOCUSEAL (e-signatures) ────────────────────────────────
# Self-host on Railway (free): https://railway.app/template/docuseal
DOCUSEAL_URL=https://your-docuseal-instance.railway.app
DOCUSEAL_API_TOKEN=your_docuseal_api_token
# Create these templates in your DocuSeal dashboard:
DOCUSEAL_ICA_TEMPLATE_ID=1
DOCUSEAL_MSA_TEMPLATE_ID=2
DOCUSEAL_NDA_TEMPLATE_ID=3
DOCUSEAL_SOW_TEMPLATE_ID=4

# ─── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_NAME=Innovate IQ LLC
NEXT_PUBLIC_COMPANY_EMAIL=info@innovateiqllc.com
